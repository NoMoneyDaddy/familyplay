# 複製成 apps/mobile/.env 後填入實際值（Expo 會自動載入 EXPO_PUBLIC_ 前綴變數）
# 正式 Supabase 專案值可在 Supabase Dashboard > Project Settings > API 取得。

EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# 深連結 / OAuth callback 用的 App 網址（正式站）
EXPO_PUBLIC_APP_URL=https://familyplay.nomoneydaddy.app

# AI 客製活動（自帶金鑰）各服務的「預設模型名稱」。非機密、可公開（EXPO_PUBLIC_）。
# 留空時使用者需在 App 設定自行填模型名稱，否則無法生成。填各服務文件提供的模型名稱。
EXPO_PUBLIC_AI_GEMINI_MODEL=
EXPO_PUBLIC_AI_GROQ_MODEL=
EXPO_PUBLIC_AI_OPENAI_MODEL=
