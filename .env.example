# ─────────────────────────────────────────────────────────
# Supabase（本機開發）
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ⚠️  只能在後端使用，絕對不能加 NEXT_PUBLIC_ 前綴
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ─────────────────────────────────────────────────────────
# Google OAuth（Supabase Auth 管理）
# ─────────────────────────────────────────────────────────
# 在 Supabase Dashboard > Authentication > Providers > Google 設定
# 這裡只在自訂 OAuth Flow 時才需要
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret   # 只限後端

# ─────────────────────────────────────────────────────────
# AI 速率限制（Upstash Redis）
# ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────
# 付費
# Web：LemonSqueezy（個人開發者友善，代理稅務）
# Mobile：RevenueCat（Apple IAP + Google Play 統一管理）
#
# 輕營利取向定價（在 LemonSqueezy 後台建立對應 variant，價格須與 pricing 頁顯示一致）：
#   - 支持者 (supporter)：月費 NT$90（贊助式入門：無廣告、完整歷史、家庭共享、匯出）
#   - Plus 月費：NT$170（AI 客製活動、加密筆記、每月 100 次 AI、交接摘要、優先支援）
#   - Plus 年費（選填）：建議 NT$1,700（約省 2 個月，目前 checkout 尚未使用年費）
#   核心「30 秒陪伴方案」與活動庫永久免費，付費為選擇性支持。
# ─────────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=                            # 只限後端
LEMONSQUEEZY_WEBHOOK_SECRET=                     # 只限後端
LEMONSQUEEZY_STORE_ID=                           # 只限後端（lib/payment 讀此變數）
LEMONSQUEEZY_SUPPORTER_VARIANT_ID=               # → entitlements.plan = 'supporter'
LEMONSQUEEZY_PLUS_MONTHLY_VARIANT_ID=            # → entitlements.plan = 'plus'（含 100 次/月 AI）
LEMONSQUEEZY_PLUS_YEARLY_VARIANT_ID=             # 選填（checkout 目前僅用月費）

REVENUECAT_SECRET_KEY=                           # 只限後端，用於 webhook 驗證（選填）
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY=               # 可公開（RevenueCat 設計），必須設定進行移動支付

# ─────────────────────────────────────────────────────────
# 輕度廣告（Google AdSense）— 主要獲利來源；只對免費用戶顯示，付費用戶不顯示
# 未設定則完全不載入廣告腳本、頁面無任何廣告（dormant）
# client/slot 皆為公開值（會出現在頁面），故用 NEXT_PUBLIC_ 前綴
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=                      # 例：ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=                        # AdSense 廣告單元 slot ID（推薦結果頁底部）

# ─────────────────────────────────────────────────────────
# 監控（選填，Sprint 11 才需要完整設定）
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=                                      # 同上，供 server/edge 使用（DSN 本身非機密）
SENTRY_AUTH_TOKEN=                               # 只限後端（上傳 source map 用）
SENTRY_ORG=
SENTRY_PROJECT=

NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ─────────────────────────────────────────────────────────
# FamilyPlay Plus 共享 AI 額度池（只限後端，Sprint 10 才需要）
# ─────────────────────────────────────────────────────────
FAMILYPLAY_GEMINI_KEY=
FAMILYPLAY_OPENAI_KEY=
FAMILYPLAY_CLAUDE_KEY=

# ─────────────────────────────────────────────────────────
# 通知
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                              # 只限後端
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────
# 應用程式
# ─────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─────────────────────────────────────────────────────────
# Zeabur 部署（不需要在本機設定，在 Zeabur Dashboard 設定環境變數）
# ─────────────────────────────────────────────────────────
# Zeabur 透過 GitHub 整合自動部署，不需要 CI Token
# 在 Zeabur Dashboard > 服務 > 環境變數 中設定正式版的所有變數
# 選擇 Taiwan (Taipei) 節點

# ─────────────────────────────────────────────────────────
# Apple Developer（Sprint 5 iOS 上架時填入）
# ─────────────────────────────────────────────────────────
# APPLE_ID=your-apple-id@email.com
# APPLE_TEAM_ID=
# ASC_APP_ID=                                    # App Store Connect App ID
