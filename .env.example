# ─────────────────────────────────────────────────────────
# Supabase（本機開發）
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-local-anon-key

# ⚠️  只能在後端使用，絕對不能加 NEXT_PUBLIC_ 前綴
SUPABASE_SERVICE_ROLE_KEY=your-local-service-role-key

# ─────────────────────────────────────────────────────────
# Google OAuth（Supabase Auth 管理）
# ─────────────────────────────────────────────────────────
# 在 Supabase Dashboard > Authentication > Providers > Google 設定
# 這裡只在自訂 OAuth Flow 時才需要
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret   # 只限後端

# ─────────────────────────────────────────────────────────
# AI 速率限制（Upstash Redis）
# ─────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─────────────────────────────────────────────────────────
# 付費 — 統一走 RevenueCat（行動端 IAP + Web Billing）
#
# 輕營利取向定價（在 RevenueCat 後台建立對應 product/package，價格須與 pricing 頁一致）：
#   - 支持者 (supporter)：月費 NT$90（贊助式入門：無廣告、完整歷史、家庭共享、匯出）
#   - Plus 月費：NT$170（AI 客製活動、加密筆記、每月 100 次 AI、交接摘要、優先支援）
#   核心「30 秒陪伴方案」與活動庫永久免費，付費為選擇性支持。
# ─────────────────────────────────────────────────────────

REVENUECAT_SECRET_KEY=                           # 只限後端，RevenueCat REST API（選填）
NEXT_PUBLIC_REVENUECAT_PUBLIC_KEY=               # 可公開（RevenueCat 設計），Web Billing 用；未設定時網頁端不開放結帳
NEXT_PUBLIC_REVENUECAT_SUPPORTER_PACKAGE=        # RevenueCat package identifier → 支持者（Web Billing）
NEXT_PUBLIC_REVENUECAT_PLUS_PACKAGE=             # RevenueCat package identifier → Plus（Web Billing）
# RevenueCat 統一收費 webhook（/api/revenuecat/webhook）— entitlements 只由此 service-role 寫
REVENUECAT_WEBHOOK_AUTH=                          # 只限後端，RevenueCat 後台設定的 Authorization 標頭固定值
REVENUECAT_SUPPORTER_ENTITLEMENT=supporter       # RevenueCat entitlement id → plan=supporter
REVENUECAT_PLUS_ENTITLEMENT=plus                 # RevenueCat entitlement id → plan=plus（含 100 次/月 AI）
REVENUECAT_SUPPORTER_PRODUCT_IDS=                # 後備：逗號分隔的 product_id（各 store 不同）
REVENUECAT_PLUS_PRODUCT_IDS=                     # 後備：逗號分隔的 product_id（各 store 不同）

# ─────────────────────────────────────────────────────────
# 輕度廣告（Google AdSense）— 主要獲利來源；只對免費用戶顯示，付費用戶不顯示
# 未設定則完全不載入廣告腳本、頁面無任何廣告（dormant）
# client/slot 皆為公開值（會出現在頁面），故用 NEXT_PUBLIC_ 前綴
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ADSENSE_CLIENT=                      # 例：ca-pub-XXXXXXXXXXXXXXXX
NEXT_PUBLIC_ADSENSE_SLOT=                        # AdSense 廣告單元 slot ID（推薦結果頁底部）

# ─────────────────────────────────────────────────────────
# 監控（選填，Sprint 11 才需要完整設定）
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=                                      # 同上，供 server/edge 使用（DSN 本身非機密）
SENTRY_AUTH_TOKEN=                               # 只限後端（上傳 source map 用）
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_URL=                                      # 後台 Admin Dashboard 的 Sentry 連結（選填）

# PostHog（後台 Admin Dashboard 用，只限後端）。
# ⚠️ 後端 admin 指標讀的是下列 server 端變數（lib/admin/metrics.ts），
#    不是 NEXT_PUBLIC_POSTHOG_*；目前沒有 client 端 PostHog 初始化。
POSTHOG_API_KEY=                                 # PostHog Personal API Key（只限後端）
POSTHOG_PROJECT_ID=                              # PostHog 專案 ID
POSTHOG_HOST=https://us.posthog.com              # 預設 us.posthog.com

# ─────────────────────────────────────────────────────────
# FamilyPlay Plus 共享 AI 額度池（只限後端，Sprint 10 才需要）
# ─────────────────────────────────────────────────────────
FAMILYPLAY_GEMINI_KEY=
FAMILYPLAY_OPENAI_KEY=
FAMILYPLAY_CLAUDE_KEY=

# Plus「託管金鑰」AI 生成（/api/ai/activity 在 request 不帶 provider 時使用）。
# provider 須為 gemini|groq|openai|ollama 之一；未設定則託管生成停用、BYO 不受影響。
# 金鑰只在後端使用，絕不加 NEXT_PUBLIC_ 前綴。
AI_MANAGED_PROVIDER=
AI_MANAGED_KEY=
AI_MANAGED_MODEL=

# BYO（自帶金鑰）各 provider 預設模型（不在 repo 寫死 model 版本碼）
AI_GEMINI_MODEL=
AI_GROQ_MODEL=
AI_OPENAI_MODEL=
AI_OLLAMA_MODEL=
# 只限後端，ollama base URL（防 SSRF；未設則停用 ollama）
AI_OLLAMA_URL=

# ─────────────────────────────────────────────────────────
# 後台 Admin Dashboard（/admin，只限後端）
# ─────────────────────────────────────────────────────────
ADMIN_EMAILS=                                    # 逗號分隔的管理員 email；未設則 /admin 一律擋下
GITHUB_TOKEN=                                    # 讀 CI/部署狀態的 GitHub token（admin 指標用，選填）
GITHUB_REPO=                                     # 例：NoMoneyDaddy/familyplay（admin 指標用）

# ─────────────────────────────────────────────────────────
# Web Push 推播（陪伴提醒；只限後端，NEXT_PUBLIC_ 公鑰例外）
# 產生金鑰：npx web-push generate-vapid-keys
# ─────────────────────────────────────────────────────────
NEXT_PUBLIC_VAPID_PUBLIC_KEY=                    # 可公開（前端訂閱用）
VAPID_PRIVATE_KEY=                               # 只限後端，絕不公開
VAPID_SUBJECT=                                   # mailto:you@example.com 或站台 URL
CRON_SECRET=                                     # 排程觸發 /api/push/send-reminders 的鑑權密鑰

# ─────────────────────────────────────────────────────────
# 通知
# ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=                              # 只限後端
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────
# 應用程式
# ─────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=0.1.0

# ─────────────────────────────────────────────────────────
# Zeabur 部署（不需要在本機設定，在 Zeabur Dashboard 設定環境變數）
# ─────────────────────────────────────────────────────────
# Zeabur 透過 GitHub 整合自動部署，不需要 CI Token
# 在 Zeabur Dashboard > 服務 > 環境變數 中設定正式版的所有變數
# 選擇 Taiwan (Taipei) 節點

# ─────────────────────────────────────────────────────────
# Apple Developer（Sprint 5 iOS 上架時填入）
# ─────────────────────────────────────────────────────────
# APPLE_ID=your-apple-id@email.com
# APPLE_TEAM_ID=
# ASC_APP_ID=                                    # App Store Connect App ID
